# SenBonsPlans — production environment template.
# Copy to `.env` and fill in real values before `pnpm build && pnpm start`.
# See LAUNCH.md §2 for the authoritative reference.

# ─── Required ───────────────────────────────────────────────────────────
# MySQL connection string. Example format: mysql://user:pass@host:3306/dbname
DATABASE_URL=

# Public origin. Used in confirmation emails + order-tracking links.
APP_URL=https://senbonsplans.example

# Session signing key. Generate with: openssl rand -hex 32
JWT_SECRET=

# SMTP for transactional email (order confirmation, status updates, newsletter).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@senbonsplans.example
SMTP_PASSWORD=
SMTP_FROM=SenBonsPlans <noreply@senbonsplans.example>

# Who receives new-order notifications.
ADMIN_EMAIL=orders@senbonsplans.example

# Must be `production` for a real deploy.
NODE_ENV=production

# ─── Dev-only ───────────────────────────────────────────────────────────
# Do NOT set in production. When true + NODE_ENV!=production, bypasses OAuth
# and returns a synthetic admin user — used only for local UI previews.
# ALLOW_DEV_ADMIN=true

# ─── Optional but recommended ───────────────────────────────────────────
# Server-side Sentry error monitoring (no-op when unset).
SENTRY_DSN=
# Client-side Sentry — build-time, rebuild after change.
VITE_SENTRY_DSN=
# Sampling rate for server / client APM (0.0–1.0, default 0).
SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_TRACES_SAMPLE_RATE=0
# Release tag for Sentry (e.g. git SHA).
APP_RELEASE=
VITE_APP_RELEASE=
# Reply-To header on customer emails.
SMTP_REPLY_TO=

# ─── OAuth (optional — Manus platform integration) ──────────────────────
OAUTH_SERVER_URL=
