# GlowBeauty — production environment template.
# Copy to `.env` and fill in real values before `pnpm build && pnpm start`.
# See LAUNCH.md §2 for the authoritative reference.

# ─── Required ───────────────────────────────────────────────────────────
# MySQL connection string. Example format: mysql://user:pass@host:3306/dbname
DATABASE_URL=

# Public origin. Used in confirmation emails + order-tracking links.
APP_URL=https://glowbeauty.example

# Session signing key. Generate with: openssl rand -hex 32
JWT_SECRET=

# SMTP for transactional email (order confirmation, status updates, newsletter).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@glowbeauty.example
SMTP_PASSWORD=
SMTP_FROM=GlowBeauty <noreply@glowbeauty.example>

# Who receives new-order notifications.
ADMIN_EMAIL=orders@glowbeauty.example

# Must be `production` for a real deploy.
NODE_ENV=production

# ─── Dev-only ───────────────────────────────────────────────────────────
# Do NOT set in production. When true + NODE_ENV!=production, bypasses OAuth
# and returns a synthetic admin user — used only for local UI previews.
# ALLOW_DEV_ADMIN=true

# ─── Optional but recommended ───────────────────────────────────────────
# Server-side Sentry error monitoring (no-op when unset).
SENTRY_DSN=
# Client-side Sentry — build-time, rebuild after change.
VITE_SENTRY_DSN=
# Sampling rate for server / client APM (0.0–1.0, default 0).
SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_TRACES_SAMPLE_RATE=0
# Release tag for Sentry (e.g. git SHA).
APP_RELEASE=
VITE_APP_RELEASE=
# Reply-To header on customer emails.
SMTP_REPLY_TO=

# ─── OAuth (optional — Manus platform integration) ──────────────────────
OAUTH_SERVER_URL=

# ─── AI / Chatbot ───────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Mobile Money — API credentials ─────────────────────────────────────
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/dev/v1
ORANGE_MONEY_API_KEY=
WAVE_API_URL=https://api.wave.com/v1
WAVE_API_KEY=
FREE_MONEY_API_URL=https://api.free.sn/v1
FREE_MONEY_API_KEY=

# ─── Mobile Money — Webhook secrets (CRITICAL) ──────────────────────────
# HMAC-SHA256 secrets — must match what is set in each provider's dashboard.
# Server returns 503 in production if any configured provider's secret is missing.
ORANGE_MONEY_WEBHOOK_SECRET=
WAVE_WEBHOOK_SECRET=
FREE_MONEY_WEBHOOK_SECRET=

# ─── Admin backup login ──────────────────────────────────────────────────
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=

# ─── Tuning (optional — defaults are safe) ──────────────────────────────
# JSON_BODY_LIMIT=512kb
# LARGE_JSON_BODY_LIMIT=5mb
# ENABLE_LEGACY_CHAT_ROUTE=false
